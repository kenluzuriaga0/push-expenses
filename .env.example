# ── Actual Budget ─────────────────────────────────────────────────────────────
# URL de tu servidor Actual Budget (sin barra final)
ACTUAL_SERVER_URL=http://192.168.1.10:5006

# Contraseña del servidor Actual Budget
ACTUAL_PASSWORD=tu_password_de_actual

# Sync ID del presupuesto: Actual Budget → Settings → Show advanced settings → Sync ID
ACTUAL_BUDGET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Nombre exacto de la cuenta donde se registrarán las transacciones
ACTUAL_ACCOUNT_NAME=Tarjeta de Crédito

# Directorio local donde Actual guarda caché del presupuesto (se crea automáticamente)
# ACTUAL_DATA_DIR=.actual-data


# ── Microsoft Graph / Outlook ──────────────────────────────────────────────────
# Application (client) ID de tu app registrada en portal.azure.com
# Ver README.md para instrucciones de registro
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# ── Filtros de email ───────────────────────────────────────────────────────────
# Regex para identificar emails de consumo.
# IMPORTANTE: el último grupo numérico capturado debe ser el monto en dólares.
EMAIL_SUBJECT_REGEX=Consumo Tarjeta de Crédito por (?:USD|\$) ([\d.]+)

# Categoría que se asigna al email una vez procesado (evita reprocesarlo)
PROCESSED_LABEL=ActualBudget

# Buscar emails a partir de esta fecha (formato YYYY-MM-DD).
# Si se define, ignora EMAIL_LIMIT y trae todos los correos desde esa fecha.
# EMAIL_FROM_DATE=2026-06-01

# Si no se define EMAIL_FROM_DATE, trae los últimos N correos del inbox (default: 50).
# EMAIL_LIMIT=50
